{
  "name": "Nexus Protocol Dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && if [ -f requirements-dev.txt ]; then pip install -r requirements-dev.txt; fi && if [ -f playwright-tool/package.json ]; then cd playwright-tool && npm install; fi",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.flake8",
        "dbaeumer.vscode-eslint",
        "juanblanco.solidity",
        "nomicfoundation.hardhat-solidity",
        "ackeeblockchain.tools-for-solidity",
        "cyfrin.aderyn",
        "github.vscode-github-actions",
        "davidanson.vscode-markdownlint",
        "bierner.markdown-mermaid",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh"
      ],
      "settings": {
        "python-envs.defaultEnvManager": "ms-python.python:conda",
        "python-envs.defaultPackageManager": "ms-python.python:conda"
      }
    }
  }
}
