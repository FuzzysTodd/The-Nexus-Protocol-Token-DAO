<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nexus – Approval Service</title>

  <script src="https://unpkg.com/ethers@6.8.1/dist/ethers.umd.min.js"></script>
  <script src="https://unpkg.com/@reown/appkit@latest/dist/appkit.umd.js"></script>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0d1117;
      color: #e6edf3;
      margin: 0;
      padding: 20px;
    }
    h1 {
      text-align: center;
      color: #58a6ff;
    }
    .card {
      background: #161b22;
      padding: 20px;
      border-radius: 10px;
      max-width: 600px;
      margin: 20px auto;
      box-shadow: 0 0 10px rgba(0,0,0,0.4);
    }
    button {
      background: #238636;
      color: white;
      padding: 12px 20px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
      margin-top: 10px;
    }
    button:hover {
      background: #2ea043;
    }
    input {
      width: 100%;
      padding: 10px;
      margin-top: 8px;
      border-radius: 6px;
      border: 1px solid #30363d;
      background: #0d1117;
      color: #e6edf3;
    }
    .status {
      margin-top: 15px;
      padding: 10px;
      background: #21262d;
      border-radius: 6px;
      font-size: 14px;
      white-space: pre-line;
    }
  </style>
</head>

<body>

  <h1>Nexus Approval Service</h1>

  <div class="card">
    <h2>Wallet Connection</h2>
    <div id="wallet-status">Not connected</div>
    <button id="connect-btn">Connect Wallet</button>
  </div>

  <div class="card">
    <h2>Token Allowance</h2>

    <label>Token Contract Address</label>
    <input id="token-address" placeholder="0x... ERC20 token" />

    <label>Spender Address</label>
    <input id="spender-address" placeholder="0x... contract needing approval" />

    <button id="check-allowance">Check Allowance</button>

    <div id="allowance-result" class="status"></div>

    <h3>Approve Allowance</h3>

    <label>Amount (leave blank for unlimited)</label>
    <input id="approve-amount" placeholder="1000000 or blank for max" />

    <button id="approve-btn">Approve</button>

    <div id="approve-status" class="status"></div>
  </div>

<script>
  let provider, signer, userAddress;

  // Initialize Reown AppKit
  const appKit = new window.AppKit({
    projectId: "nexus-approval-service",
    metadata: {
      name: "Nexus Approval Service",
      description: "Approve ERC20 allowances for Nexus Protocol",
      url: window.location.href,
      icons: []
    }
  });

  document.getElementById("connect-btn").onclick = async () => {
    try {
      const session = await appKit.connect();
      provider = new ethers.BrowserProvider(appKit.getWalletProvider());
      signer = await provider.getSigner();
      userAddress = await signer.getAddress();

      document.getElementById("wallet-status").innerText =
        "Connected: " + userAddress;
    } catch (err) {
      document.getElementById("wallet-status").innerText =
        "Connection failed: " + err.message;
    }
  };

  document.getElementById("check-allowance").onclick = async () => {
    try {
      const token = document.getElementById("token-address").value.trim();
      const spender = document.getElementById("spender-address").value.trim();

      if (!token || !spender) {
        return alert("Token + Spender required");
      }

      const abi = ["function allowance(address owner, address spender) view returns (uint256)"];
      const contract = new ethers.Contract(token, abi, provider);

      const allowance = await contract.allowance(userAddress, spender);

      document.getElementById("allowance-result").innerText =
        "Current Allowance:\n" + allowance.toString();
    } catch (err) {
      document.getElementById("allowance-result").innerText =
        "Error: " + err.message;
    }
  };

  document.getElementById("approve-btn").onclick = async () => {
    try {
      const token = document.getElementById("token-address").value.trim();
      const spender = document.getElementById("spender-address").value.trim();
      const amountInput = document.getElementById("approve-amount").value.trim();

      const amount = amountInput
        ? ethers.parseUnits(amountInput, 18)
        : ethers.MaxUint256;

      const abi = ["function approve(address spender, uint256 amount) returns (bool)"];
      const contract = new ethers.Contract(token, abi, signer);

      const tx = await contract.approve(spender, amount);

      document.getElementById("approve-status").innerText =
        "Transaction sent:\n" + tx.hash;

      const receipt = await tx.wait();

      document.getElementById("approve-status").innerText =
        "Approval confirmed in block " + receipt.blockNumber;
    } catch (err) {
      document.getElementById("approve-status").innerText =
        "Error: " + err.message;
    }
  };
</script>

</body>
</html>
